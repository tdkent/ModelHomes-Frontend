		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"lint-staged": "^16.2.7",
		"tw-animate-css": "^1.4.0",
		"typescript": "~5.9.3",
		"vite": "^7.2.4",
		"vitest": "^4.0.18"
