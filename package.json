{
	"name": "ggiemh-frontend",
	"description": "Frontend UI for the Model Homes of the Golden Gate International Exposition website.",
	"author": "Tim Kent <timkentdev@gmail.com>",
	"homepage": "https://github.com/tdkent/ggiemh-frontend#readme",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"build": "tsc -b && vite build",
		"dev": "vite",
		"lint": "biome check --verbose",
		"lint:fix": "biome check --write --no-errors-on-unmatched",
		"prepare": "husky",
		"preview": "vite preview",
		"test": "vitest"
	},
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched --verbose"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.563.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router": "^7.13.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
